{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "active":      { "type": "boolean", "default": false },
    "roots":       { "type": "array", "items": { "type": "string" }, "default": ["Frameworks"] },
    "output":      { "type": "string", "default": "memory/semantic/frameworks.jsonl" },
    "extensions":  { "type": "array", "items": { "type": "string" }, "default": [".md"] }
  }
}
